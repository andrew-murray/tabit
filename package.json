{
  "name": "tabit",
  "homepage": "http://andrew-murray.github.io/tabit",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.0.1",
    "@mui/lab": "9.0.0-beta.3",
    "@mui/material": "9.0.1",
    "@mui/styles": "6.4.8",
    "copy-to-clipboard": "4.0.2",
    "fast-xml-parser": "5.7.3",
    "file-saver": "2.0.5",
    "memoize-one": "6.0.0",
    "object-hash": "3.0.0",
