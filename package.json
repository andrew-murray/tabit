    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "react-test-renderer": "19.2.6",
    "serve": "^14.2.6",
    "vite": "^8.0.11",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.1.5"
  }
